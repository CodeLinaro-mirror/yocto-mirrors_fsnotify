# Rename nested directory.
require recurse

mkdir -p /sub/dir
watch /...

mv /sub /sub-rename
touch /sub-rename/file
touch /sub-rename/dir/file

Output:
	rename     /sub                  # mv /sub /sub-rename
	create     /sub-rename ← /sub

	write      /sub-rename           # touch /sub-rename/file
	create     /sub-rename/file

	create     /sub-rename/dir/file  # touch /sub-rename/dir/file

	linux:  # Same as Windows, but without those stupid dir writes Windows sends.
		rename     /sub                  # mv /sub /sub-rename
		create     /sub-rename

		create     /sub-rename/file      # touch /sub-rename/file

		create     /sub-rename/dir/file  # touch /sub-rename/dir/file

# IN_ISDIR | IN_MOVED_FROM   → "/tmp/TestScriptwatch-recurserename-dir3536106279/001/sub"
# IN_ISDIR | IN_MOVED_TO     → "/tmp/TestScriptwatch-recurserename-dir3536106279/001/sub-rename"
# IN_MOVE_SELF               → "/tmp/TestScriptwatch-recurserename-dir3536106279/001/sub"

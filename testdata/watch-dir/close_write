# Basic close_write test
require close_write

watch /   default close_write

touch /file
echo "hello, world!" >>/file
echo "hello, world!" >/file

Output:
	create        /file  # touch
	close_write   /file

	write         /file  # echo >>
	close_write   /file

	write         /file  # echo >
	write         /file
	close_write   /file
